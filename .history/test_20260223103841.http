@baseUrl = http://192.168.1.15:8000/api
@contentType = application/json

############################################################
### TEST 1 - Vérifier API
GET {{baseUrl}}/
Accept: {{contentType}}

############################################################
### TEST 2 - Créer un ADMIN
POST {{baseUrl}}/users/
Content-Type: {{contentType}}

{
  "nom": "Admin",
  "prenom": "System",
  "email": "admin@test.com",
  "password": "123456",
  "role": "ADMIN",
  "statut": "ACTIF"
}

############################################################
### TEST 3 - Créer un MANAGER
POST {{baseUrl}}/users/
Content-Type: {{contentType}}

{
  "nom": "Manager",
  "prenom": "Fatou",
  "email": "manager@test.com",
  "password": "123456",
  "role": "MANAGER",
  "statut": "ACTIF"
}

############################################################
### TEST 4 - Créer un EMPLOYE
POST {{baseUrl}}/users/
Content-Type: {{contentType}}

{
  "nom": "Employe",
  "prenom": "Ali",
  "email": "employe@test.com",
  "password": "123456",
  "role": "EMPLOYE",
  "statut": "ACTIF"
}

############################################################
### TEST 5 - Lister les users
GET {{baseUrl}}/users/
Accept: {{contentType}}

############################################################
### TEST 6 - Login
POST {{baseUrl}}/auth/login/
Content-Type: {{contentType}}

{
  "email": "admin@test.com",
  "password": "123456"
}

############################################################
### TEST 7 - Générer QR Code pour employé
POST {{baseUrl}}/qr/generate/
Content-Type: {{contentType}}

{
  "user_id": 3
}

############################################################
### TEST 8 - Scanner QR Code (ENTREE)
POST {{baseUrl}}/qr/scan/
Content-Type: {{contentType}}

{
  "qr_code": "QR_CODE_DATA",
  "type": "ENTREE",
  "localisation": "Dakar"
}

############################################################
### TEST 9 - Scanner QR Code (SORTIE)
POST {{baseUrl}}/qr/scan/
Content-Type: {{contentType}}

{
  "qr_code": "QR_CODE_DATA",
  "type": "SORTIE",
  "localisation": "Dakar"
}

############################################################
### TEST 10 - Créer une absence
POST {{baseUrl}}/absences/
Content-Type: {{contentType}}

{
  "user": 3,
  "date_debut": "2026-02-20",
  "date_fin": "2026-02-22",
  "type_absence": "CONGE_ANNUEL",
  "motif": "Vacances"
}

############################################################
### TEST 11 - Lister absences
GET {{baseUrl}}/absences/
Accept: {{contentType}}

############################################################
### TEST 12 - Valider absence (MANAGER)
PUT {{baseUrl}}/absences/1/valider/
Content-Type: {{contentType}}

############################################################
### TEST 13 - Voir pointages
GET {{baseUrl}}/pointages/
